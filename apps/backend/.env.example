NODE_ENV=development
PORT=4000
JSON_BODY_LIMIT=8mb
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecomind
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=true
PGPOOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=10000
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:8081,http://localhost:19006
TRUST_PROXY=1
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=25
RATE_LIMIT_SIGNUP_MAX=8
RATE_LIMIT_CHAT_MAX=40
AUTH_FAIL_MAX_15M=5
CHAT_MIN_INTERVAL_MS=2000
CHAT_DUPLICATE_WINDOW_MS=60000
MATCH_COMPATIBILITY_THRESHOLD=75
